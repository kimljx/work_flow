# 工作流管理系统配置模板
# 使用方式：
# Windows: copy .env.example .env
# Linux:   cp .env.example .env

# 应用基础配置
APP_NAME=工作流管理系统
APP_ENV=dev
SECRET_KEY=Xk7pQ2mN9vR4tY8wL3jH5sD1fG6bC0aZ
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./backend/data/app.db
DEFAULT_PASSWORD=ChangeMe123
QAX_COLLECT_CRON=0 * * * *
REMIND_DAILY_RUN_AT=09:00

# SMTP 发信配置
SMTP_HOST=smtp.example.com
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

# IMAP 收件配置
MAIL_INBOX_PROTOCOL=imap
MAIL_INBOX_MAX_SCAN=20
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_TLS=false
IMAP_USE_SSL=true

# POP3 收件配置
POP3_HOST=
POP3_PORT=110
POP3_USER=
POP3_PASSWORD=
POP3_USE_TLS=false
POP3_USE_SSL=false

# 兼容旧配置字段，保留读取但建议改用 MAIL_INBOX_MAX_SCAN
IMAP_MAX_UNSEEN_SCAN=20
MAIL_AUTO_POLL_ENABLED=false
MAIL_AUTO_POLL_INTERVAL_SECONDS=300

# 配置说明
# 1. SMTP_USE_SSL=true 通常用于 465 端口。
# 2. SMTP_USE_TLS=true 通常用于 587 端口，此时 SMTP_USE_SSL 应为 false。
# 3. 25 端口通常保持 SMTP_USE_SSL=false，是否开启 SMTP_USE_TLS 取决于服务商是否要求 STARTTLS。
# 4. SMTP_USE_SSL 与 SMTP_USE_TLS 不要同时为 true，否则容易出现 wrong version number 之类的 SSL 握手错误。
# 5. MAIL_INBOX_PROTOCOL 可选 imap 或 pop3，用于指定自动收件协议。
# 6. 993 端口通常使用 IMAP_USE_SSL=true，143 端口通常使用 IMAP_USE_SSL=false。
# 7. 如服务商要求 STARTTLS，可在 143 端口下将 IMAP_USE_TLS=true。
# 8. 995 端口通常使用 POP3_USE_SSL=true，110 端口通常使用 POP3_USE_SSL=false。
# 9. 如服务商要求 STLS，可在 110 端口下将 POP3_USE_TLS=true。
# 10. 收件协议的 SSL 与 TLS 开关不要同时为 true。
# 11. MAIL_INBOX_MAX_SCAN 用于限制每次最多扫描最近多少封邮件。
# 12. 首次接入建议先在邮件模块设置扫描基准时间，避免历史邮件被一次性批量处理。
