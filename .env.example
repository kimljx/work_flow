# 部门任务协同系统配置模板
# 使用方法：复制本文件为项目根目录下的 .env，再按实际环境修改。
# Windows：copy .env.example .env
# Linux：cp .env.example .env

# 应用基础配置
APP_NAME=部门任务协同系统
APP_ENV=dev
SECRET_KEY=请替换为至少32位随机字符串
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./backend/data/app.db
DEFAULT_PASSWORD=ChangeMe123
QAX_COLLECT_CRON=0 * * * *
REMIND_DAILY_RUN_AT=09:00

# SMTP 发信配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=coder.ljx@qq.com
SMTP_PASSWORD=vcskrykrpzdyeabi
SMTP_FROM_ADDRESS=coder.ljx@qq.com
SMTP_USE_TLS=false
SMTP_USE_SSL=true
SMTP_TIMEOUT_SECONDS=20

# IMAP 收件配置
IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_USER=coder.ljx@qq.com
IMAP_PASSWORD=vcskrykrpzdyeabi
IMAP_MAX_UNSEEN_SCAN=20
MAIL_AUTO_POLL_ENABLED=true
MAIL_AUTO_POLL_INTERVAL_SECONDS=300

# 配置说明
# 1. SMTP_USE_SSL=true 通常用于 465 端口。
# 2. SMTP_USE_TLS=true 通常用于 587 端口，此时 SMTP_USE_SSL 应为 false。
# 3. IMAP_MAX_UNSEEN_SCAN 用于限制每次只扫描最近多少封未读邮件。
# 4. 首次接入建议先在“通知中心”点击“设置首次扫描基准时间”，之后系统只会扫描该时间之后的新未读邮件。
