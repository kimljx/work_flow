# 内网离线发布包环境模板
# 使用方式：复制为 app\.env 后再按实际环境修改

APP_NAME=工作流管理系统
APP_ENV=prod
SECRET_KEY=请替换为至少32位随机字符串
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./backend/data/app.db
DEFAULT_PASSWORD=ChangeMe123
QAX_COLLECT_CRON=0 * * * *
REMIND_DAILY_RUN_AT=09:00

# 内网部署建议默认关闭自动收件，待邮箱配置完成后再开启
MAIL_AUTO_POLL_ENABLED=false
MAIL_AUTO_POLL_INTERVAL_SECONDS=300
MAIL_INBOX_PROTOCOL=imap
MAIL_INBOX_MAX_SCAN=20
IMAP_MAX_UNSEEN_SCAN=20

# SMTP 发信配置
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

# 配置提示：
# 1. 465 端口通常使用 SMTP_USE_SSL=true 且 SMTP_USE_TLS=false。
# 2. 587 端口通常使用 SMTP_USE_TLS=true 且 SMTP_USE_SSL=false。
# 3. 25 端口通常保持 SMTP_USE_SSL=false，是否开启 SMTP_USE_TLS 取决于服务商是否要求 STARTTLS。
# 4. SMTP_USE_SSL 与 SMTP_USE_TLS 不要同时为 true，否则容易出现 wrong version number 之类的 SSL 握手错误。

# IMAP 收件配置
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_TLS=false
IMAP_USE_SSL=true

# POP3 收件配置
POP3_HOST=
POP3_PORT=110
POP3_USER=
POP3_PASSWORD=
POP3_USE_TLS=false
POP3_USE_SSL=false

# 配置提示：
# 1. MAIL_INBOX_PROTOCOL 可选 imap 或 pop3。
# 2. 993 端口通常使用 IMAP_USE_SSL=true 且 IMAP_USE_TLS=false。
# 3. 143 端口通常使用 IMAP_USE_SSL=false，是否开启 IMAP_USE_TLS 取决于服务商是否要求 STARTTLS。
# 4. 995 端口通常使用 POP3_USE_SSL=true 且 POP3_USE_TLS=false。
# 5. 110 端口通常使用 POP3_USE_SSL=false，是否开启 POP3_USE_TLS 取决于服务商是否要求 STLS。
# 6. 收件协议的 SSL 与 TLS 开关不要同时为 true，否则容易出现 wrong version number 之类的握手错误。
